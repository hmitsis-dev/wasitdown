# Build stage
FROM golang:1.25-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /bin/generator ./cmd/generator

# Runtime stage
FROM alpine:3.19

RUN apk add --no-cache ca-certificates tzdata

WORKDIR /app
COPY --from=builder /bin/generator /bin/generator
COPY templates /app/templates
COPY static /app/static

ENV OUTPUT_DIR=/app/dist

ENTRYPOINT ["/bin/generator"]
