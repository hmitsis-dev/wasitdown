# Used by cmd/generator when run locally (outside Docker)
DATABASE_URL=postgres://wasitdown:changeme@localhost:5432/wasitdown?sslmode=disable

# Cloudflare Pages deployment (set as GitHub Actions secrets)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
